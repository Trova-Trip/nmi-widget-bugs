# Public NMI tokenization key used by the payment widget.
# This is a client-side ("checkout public") key — it is embedded in the built
# JS bundle by design, so it is not a secret. It is kept out of the repo only
# so each user supplies their own.
#
# To run locally, copy this file and fill in your key:
#   cp .env.example .env.local
VITE_NMI_TOKENIZATION_KEY=
